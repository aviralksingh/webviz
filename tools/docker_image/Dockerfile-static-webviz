# ---- Builder ----
FROM node:18 AS builder

WORKDIR /app

# Fix Node 18 OpenSSL crypto issue for Webpack
ENV NODE_OPTIONS=--openssl-legacy-provider

# Avoid peer dep issues
RUN npm config set legacy-peer-deps true

# Install lerna globally
RUN npm install -g lerna@6

# Copy only dependency manifests (for caching)
COPY lerna.json package.json package-lock.json ./

COPY packages/@cruise-automation/button/package.json packages/@cruise-automation/button/
COPY packages/@cruise-automation/hooks/package.json packages/@cruise-automation/hooks/
COPY packages/@cruise-automation/tooltip/package.json packages/@cruise-automation/tooltip/
COPY packages/regl-worldview/package.json packages/regl-worldview/
COPY packages/webviz-core/package.json packages/webviz-core/

# Install root dependencies
RUN npm install

# Install missing dependencies explicitly to avoid build errors
RUN npm install --save \
    @sentry/types \
    int53 \
    @blueprintjs/core \
    @blueprintjs/icons \
    cbor-js

# Bootstrap monorepo with hoisting (react/react-dom)
RUN lerna bootstrap --hoist "{react,react-dom}" -- --legacy-peer-deps

# Update caniuse-lite to remove Browserslist warning
RUN npx browserslist@latest --update-db

RUN npm install --save-dev babel-loader @babel/core @babel/preset-env @babel/preset-react

# Copy full source
COPY . /app

# Build static Webviz
RUN npm run build-static-webviz

# ---- Runtime ----
FROM nginx:1-alpine

# Change default nginx port
RUN sed -i 's/listen  *80;/listen 8080;/g' /etc/nginx/conf.d/default.conf
EXPOSE 8080

# Copy build output
COPY --from=builder /app/__static_webviz__ /usr/share/nginx/html